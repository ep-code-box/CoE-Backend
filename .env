# 이 파일을 복사하여 .env 파일을 만드세요.
# cp .env.example .env
OPENAI_API_BASE=https://guest-api.sktax.chat/v1
OPENAI_API_KEY=sktax-XyeKFrq67ZjS4EpsDlrHHXV8it
OPENAI_MODEL_NAME=ax4

# Embedding 서비스 설정
EMBEDDING_SERVICE_URL=http://koEmbeddings:80
EMBEDDING_MODEL_NAME=paraphrase-multilingual-MiniLM-L12-v2-onnx

# ChromaDB 설정
CHROMA_HOST=chroma
CHROMA_PORT=8000
CHROMA_COLLECTION_NAME=coe_documents

# 데이터베이스 설정
DB_HOST=mariadb
DB_PORT=3306
DB_USER=coe_user
DB_PASSWORD=coe_password
DB_NAME=coe_db

# Redis 설정
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=coe_redis_password
REDIS_AUTH_DB=1

# JWT 인증 설정
JWT_SECRET_KEY=your-super-secret-jwt-key-change-this-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# 보안 설정 (테스트용으로 인증 비활성화)
ENFORCE_AUTH=false
RATE_LIMIT_PER_MINUTE=60

# 애플리케이션 환경
APP_ENV=development
